############################################################
# Self-hosted Supabase stack — copy to infra/.env and edit.
#
# For local dev you can use the defaults below. For production
# (VPS) regenerate every secret and JWT key. See:
#   scripts/generate-keys.sh
############################################################

# ---------- Postgres ----------
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres-dev-change-me

# ---------- JWT ----------
# IMPORTANT for migration: to preserve existing user sessions from Lovable,
# set JWT_SECRET to the SAME secret used by the Lovable Supabase project
# (Supabase dashboard → Settings → API → JWT Secret). If you only need
# passwords to keep working (not active sessions), any new secret is fine —
# users will just be logged out once and log back in.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-change-me
JWT_EXPIRY=3600

# Anon + service-role keys are JWTs signed with JWT_SECRET above.
# Generate with scripts/generate-keys.sh after setting JWT_SECRET.
ANON_KEY=
SERVICE_ROLE_KEY=

# ---------- URLs ----------
# Public URL the frontend talks to (Kong gateway). Local: http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:5173
ADDITIONAL_REDIRECT_URLS=

# ---------- Auth (GoTrue) ----------
GOTRUE_SITE_URL=${SITE_URL}
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_EXTERNAL_PHONE_ENABLED=false
GOTRUE_SMS_AUTOCONFIRM=false

# SMTP (leave blank in dev — Inbucket catches mail at http://localhost:9000)
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=inbucket
SMTP_PORT=2500
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Metrics Loom

# ---------- Studio ----------
STUDIO_DEFAULT_ORGANIZATION=Metrics Loom
STUDIO_DEFAULT_PROJECT=metrics-loom
STUDIO_PORT=3000

# ---------- Storage ----------
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800
