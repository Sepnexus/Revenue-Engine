############################################################
# Production .env for the Hostinger VPS deploy.
# Copy this file to infra/.env on the VPS and fill in.
# Never commit infra/.env.
############################################################

# ---------- public hostnames (used by Traefik) ----------
PROD_WEB_HOST=revenue.srv844822.hstgr.cloud
PROD_API_HOST=revenue-api.srv844822.hstgr.cloud
PROD_STUDIO_HOST=revenue-studio.srv844822.hstgr.cloud

# Studio basic auth — required so the admin UI isn't open to the world.
# Generate on the VPS with:  htpasswd -nbB admin 'your-password'
# Then escape every $ as $$ when pasting here.
STUDIO_BASIC_AUTH=admin:$$2y$$05$$replace-with-bcrypt-hash

# ---------- Postgres ----------
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=                        # generate: openssl rand -base64 32

# ---------- JWT ----------
# Generate locally with: scripts/generate-keys.sh
# Then paste the three values here. Never reuse dev keys in prod.
JWT_SECRET=
JWT_EXPIRY=3600
ANON_KEY=
SERVICE_ROLE_KEY=

# ---------- URLs (HTTPS) ----------
API_EXTERNAL_URL=https://revenue-api.srv844822.hstgr.cloud
SITE_URL=https://revenue.srv844822.hstgr.cloud
ADDITIONAL_REDIRECT_URLS=https://revenue.srv844822.hstgr.cloud

# ---------- Auth (GoTrue) ----------
GOTRUE_SITE_URL=${SITE_URL}
GOTRUE_DISABLE_SIGNUP=true               # prod: invite-only, no public signup
GOTRUE_MAILER_AUTOCONFIRM=false          # require email confirmation on new accounts
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_EXTERNAL_PHONE_ENABLED=false
GOTRUE_SMS_AUTOCONFIRM=false

# ---------- SMTP (real provider in prod) ----------
# Example: Resend, Postmark, SES, Mailgun, etc.
SMTP_ADMIN_EMAIL=akshay@sepnexus.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=                                # API key from your SMTP provider
SMTP_SENDER_NAME=Revenue Engine

# ---------- Studio ----------
STUDIO_DEFAULT_ORGANIZATION=Sepnexus
STUDIO_DEFAULT_PROJECT=Revenue Engine
STUDIO_PORT=3000                          # internal only — Traefik fronts it

# ---------- Storage ----------
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800
