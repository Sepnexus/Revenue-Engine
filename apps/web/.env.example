# Frontend env — copy to apps/web/.env and fill in.
#
# LOCAL DEV (against the docker-compose Supabase in infra/):
#   VITE_SUPABASE_URL=http://localhost:8000
#   VITE_SUPABASE_PUBLISHABLE_KEY=<ANON_KEY from infra/.env>
#
# PRODUCTION (VPS):
#   VITE_SUPABASE_URL=https://api.yourdomain.com
#   VITE_SUPABASE_PUBLISHABLE_KEY=<ANON_KEY from infra/.env on the VPS>
#
VITE_SUPABASE_URL="http://localhost:8000"
VITE_SUPABASE_PUBLISHABLE_KEY=""
