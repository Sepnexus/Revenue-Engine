# ─────────────────────────────────────────────────────────────────
# Revenue Engine — single-container deploy.
# Copy to .env on the server and fill every value. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# ── Public URLs (must match Traefik labels in docker-compose.yml) ──
PUBLIC_HOST=revenue.sepnexus.com
PUBLIC_API_HOST=revenue-api.sepnexus.com
SITE_URL=https://revenue.sepnexus.com
VITE_SUPABASE_URL=https://revenue-api.sepnexus.com
# Same value as ANON_KEY below — the frontend reads this name (Lovable convention).
# Both are baked into the JS bundle at build time, so you MUST set this before
# `docker compose up --build`. If left empty, every Supabase call from the
# browser silently fails with a "NETWORK_ERROR" toast.
VITE_SUPABASE_PUBLISHABLE_KEY=CHANGE_ME_same_value_as_ANON_KEY

# ── Database passwords (pick long random strings) ──
POSTGRES_DB=revenue_engine
POSTGRES_PASSWORD=CHANGE_ME_postgres_superuser_password
AUTHENTICATOR_PASSWORD=CHANGE_ME_postgrest_role_password
AUTH_ADMIN_PASSWORD=CHANGE_ME_gotrue_admin_password

# ── JWT secret + derived public keys ──
# JWT_SECRET: any random string, 40+ chars.
# ANON_KEY / SERVICE_ROLE_KEY: JWTs signed with JWT_SECRET.
# Generate all three with the helper script (see docs/DEPLOY.md Step 2):
#   ./docker/gen-keys.sh
JWT_SECRET=CHANGE_ME_jwt_secret_at_least_40_chars
ANON_KEY=CHANGE_ME_jwt_signed_with_jwt_secret_role_anon
SERVICE_ROLE_KEY=CHANGE_ME_jwt_signed_with_jwt_secret_role_service_role
